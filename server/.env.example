# CLYR MLM Platform - Server Environment Variables
# Copy this file to .env and fill in your values

# ================================
# DATABASE
# ================================
DATABASE_URL=postgresql://username:password@localhost:5432/clyr_mlm
# Or use individual variables:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=clyr_mlm
# DB_USER=username
# DB_PASSWORD=password

# ================================
# JWT AUTHENTICATION
# ================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ================================
# STRIPE PAYMENTS
# ================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ================================
# EMAIL (Nodemailer / SMTP)
# ================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM_NAME=CLYR
SMTP_FROM_EMAIL=noreply@clyr.at

# ================================
# APPLICATION
# ================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# ================================
# FILE UPLOADS
# ================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ================================
# SECURITY
# ================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ================================
# COMMISSION SETTINGS
# ================================
ADMIN_COMMISSION_RATE=50
COMMISSION_HOLD_DAYS=14
MIN_PAYOUT_AMOUNT=50
PAYOUT_DAY=1

# ================================
# PARTNER SETTINGS
# ================================
PARTNER_ANNUAL_FEE=100
ACTIVE_PARTNER_REQUIREMENT=2
